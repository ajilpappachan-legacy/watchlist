# ── TMDB API ────────────────────────────────────────────────────────────
# Get your free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Database ──────────────────────────────────────────────────────────────
# Path to SQLite file. In Docker, this maps to the volume mount.
# Defaults to ./data/watchlist.db if not set.
DATABASE_PATH=./data/watchlist.db

# ── Cloudflare Tunnel (for Docker deployment) ─────────────────────────────
# Get this from: Cloudflare Zero Trust > Access > Tunnels > your tunnel > token
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
